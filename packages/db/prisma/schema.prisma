generator client {
  provider     = "prisma-client"
  output       = "../../../apps/api/src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  createdAt    DateTime       @default(now())
  users        User[]
  accounts     Account[]
  transactions Transaction[]
  invoices     Invoice[]
  employees    Employee[]
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String
  role      Role      @default(VIEWER)
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  MANAGER
  VIEWER
}

model Account {
  id          String        @id @default(uuid())
  code        String
  name        String
  type        AccountType
  balance     Decimal       @default(0) @db.Decimal(18, 2)
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  debitLines  JournalLine[] @relation("DebitAccount")
  creditLines JournalLine[] @relation("CreditAccount")
  createdAt   DateTime      @default(now())

  @@unique([code, tenantId])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Transaction {
  id          String        @id @default(uuid())
  reference   String        @unique
  description String
  date        DateTime
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  lines       JournalLine[]
  createdAt   DateTime      @default(now())
}

model JournalLine {
  id              String      @id @default(uuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  debitAccountId  String?
  debitAccount    Account?    @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String?
  creditAccount   Account?    @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount          Decimal     @db.Decimal(18, 2)
  currency        String      @default("USD")
  createdAt       DateTime    @default(now())
}

model Invoice {
  id        String        @id @default(uuid())
  number    String        @unique
  type      InvoiceType
  status    InvoiceStatus @default(DRAFT)
  amount    Decimal       @db.Decimal(18, 2)
  currency  String        @default("USD")
  dueDate   DateTime
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  createdAt DateTime      @default(now())
}

enum InvoiceType {
  PAYABLE
  RECEIVABLE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Employee {
  id           String    @id @default(uuid())
  employeeCode String    @unique
  firstName    String
  lastName     String
  email        String    @unique
  phone        String?
  department   String
  position     String
  salary       Decimal   @db.Decimal(18, 2)
  startDate    DateTime
  status       EmpStatus @default(ACTIVE)
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  payrolls     Payroll[]
  leaves       Leave[]
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
}

enum EmpStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model Payroll {
  id          String        @id @default(uuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  period      String
  grossSalary Decimal       @db.Decimal(18, 2)
  tax         Decimal       @db.Decimal(18, 2)
  deductions  Decimal       @db.Decimal(18, 2)
  netSalary   Decimal       @db.Decimal(18, 2)
  status      PayrollStatus @default(PENDING)
  tenantId    String
  createdAt   DateTime      @default(now())
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

model Leave {
  id         String      @id @default(uuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  type       LeaveType
  startDate  DateTime
  endDate    DateTime
  status     LeaveStatus @default(PENDING)
  reason     String?
  tenantId   String
  createdAt  DateTime    @default(now())
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}
model Vendor {
  id           String          @id @default(uuid())
  name         String
  email        String
  phone        String?
  address      String?
  tenantId     String
  createdAt    DateTime        @default(now())
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id         String      @id @default(uuid())
  poNumber   String      @unique
  vendorId   String
  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  status     POStatus    @default(DRAFT)
  totalAmount Decimal    @db.Decimal(18, 2)
  tenantId   String
  items      POItem[]
  createdAt  DateTime    @default(now())
}

enum POStatus {
  DRAFT
  SENT
  CONFIRMED
  RECEIVED
  CANCELLED
}

model POItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productName     String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(18, 2)
  totalPrice      Decimal       @db.Decimal(18, 2)
  createdAt       DateTime      @default(now())
}

model InventoryItem {
  id           String   @id @default(uuid())
  sku          String   @unique
  name         String
  quantity     Int      @default(0)
  reorderPoint Int      @default(10)
  unitPrice    Decimal  @db.Decimal(18, 2)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}